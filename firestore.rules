rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isFactory() {
      return signedIn() && userDoc().role == 'factory';
    }

    function isShop() {
      return signedIn() && userDoc().role == 'shop';
    }

    function isEmailAllowed(email) {
      return exists(/databases/$(database)/documents/allowedEmails/$(email));
    }

    function isAdmin() {
      return signedIn()
        && request.auth.token.email != null
        && get(/databases/$(database)/documents/allowedEmails/$(request.auth.token.email)).data.isAdmin == true;
    }

    // Allowlist — readable without auth (needed for pre-signup check),
    // writable only by admins.
    match /allowedEmails/{email} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /users/{uid} {
      allow read: if signedIn() && request.auth.uid == uid;
      allow create: if signedIn()
        && request.auth.uid == uid
        && isEmailAllowed(request.auth.token.email)
        && request.resource.data.role in ['shop', 'factory']
        && (request.resource.data.role != 'shop'
            || request.resource.data.shopName in ['Seva', 'Seva Mart', 'Seva Super Store']);
      allow update: if signedIn()
        && request.auth.uid == uid
        && (
          request.resource.data.role == resource.data.role
          || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['fcmTokens'])
        );
    }

    match /unlimitedProducts/{id} {
      allow read: if signedIn();
      allow write: if isFactory();
    }

    match /limitedProducts/{id} {
      allow read: if signedIn();
      allow create, delete: if isFactory();
      allow update: if isFactory()
        || (
          isShop()
          && request.resource.data.stock is int
          && request.resource.data.stock >= 0
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stock', 'updatedAt'])
        );
    }

    match /orders/{id} {
      allow read: if signedIn() && (isFactory() || isAdmin() || resource.data.shopUserId == request.auth.uid);
      allow create: if signedIn()
        && isShop()
        && request.resource.data.shopUserId == request.auth.uid
        && request.resource.data.shopName == userDoc().shopName
        && request.resource.data.status == 'pending';
      allow update: if isFactory();
      allow delete: if isShop()
        && resource.data.shopUserId == request.auth.uid
        && resource.data.status == 'pending';
    }

    match /settings/{doc} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /counters/{doc} {
      allow read, write: if signedIn();
    }

    match /_fcmDedup/{id} {
      allow read, write: if false;
    }
  }
}